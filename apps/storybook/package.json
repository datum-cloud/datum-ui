{
  "name": "@repo/storybook",
  "type": "module",
  "version": "1.0.4",
  "private": true,
  "scripts": {
    "predev": "[ -d '../../packages/datum-ui/dist' ] || pnpm --filter @datum-cloud/datum-ui build",
    "dev": "storybook dev -p 6006",
    "prebuild": "[ -d '../../packages/datum-ui/dist' ] && node ../../packages/datum-ui/scripts/copy-styles.mjs || pnpm --filter @datum-cloud/datum-ui build",
    "build": "storybook build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules storybook-static"
  },
  "dependencies": {
    "@datum-cloud/datum-ui": "workspace:*",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.556.0",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@repo/shadcn": "workspace:*",
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-react": "^1.4.6",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-interactions": "^8",
    "@storybook/addon-links": "^10.2.14",
    "@storybook/test": "^8",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19",
    "eslint": "^9.39.3",
    "react-day-picker": "^9.14.0",
    "recharts": "^3",
    "storybook": "^10",
    "storybook-addon-pseudo-states": "^10.3.4",
    "storybook-addon-tag-badges": "^3.1.0",
    "storybook-react-rsbuild": "^2",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9"
  }
