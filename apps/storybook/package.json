{
  "name": "@repo/storybook",
  "type": "module",
  "version": "2.0.6",
  "private": true,
  "scripts": {
    "predev": "[ -d '../../packages/datum-ui/dist' ] || pnpm --filter @datum-cloud/datum-ui build",
    "dev": "storybook dev -p 6006",
    "prebuild": "[ -d '../../packages/datum-ui/dist' ] && node ../../packages/datum-ui/scripts/copy-styles.mjs || pnpm --filter @datum-cloud/datum-ui build",
    "build": "storybook build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "concurrently -k -s first -n \"SB,TEST\" \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook\"",
    "clean": "rm -rf .turbo node_modules storybook-static"
  },
  "dependencies": {
    "@datum-cloud/datum-ui": "workspace:*",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@repo/shadcn": "workspace:*",
    "@rsbuild/core": "^2.0.15",
    "@rsbuild/plugin-react": "^2.1.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19.2.17",
    "axe-playwright": "^2.2.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "http-server": "^14.1.1",
    "react-day-picker": "^10.0.1",
    "recharts": "^3.8.1",
    "storybook": "^10.4.6",
    "storybook-addon-pseudo-states": "^10.4.6",
    "storybook-addon-tag-badges": "^3.1.0",
    "storybook-react-rsbuild": "^3.3.4",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  }
}
