{
  "name": "design-system",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:all": "turbo run clean && rm -rf node_modules .turbo && pnpm store prune",
    "fresh": "pnpm clean:all && pnpm install",
    "format": "turbo run format",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=@datum-cloud/datum-ui && changeset publish"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "lefthook": "^2.1.2",
    "turbo": "^2.8.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
